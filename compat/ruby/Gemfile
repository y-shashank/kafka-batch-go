# frozen_string_literal: true

source "https://rubygems.org"

def kafka_batch_gem_path
  ENV.fetch("KAFKA_BATCH_GEM_PATH") do
    candidates = [
      File.expand_path("../kafka-batch", __dir__),       # CI checkout at repo/kafka-batch
      File.expand_path("../../../kafka-batch", __dir__)  # local sibling clone
    ]
    found = candidates.find { |p| File.directory?(File.join(p, "lib")) }
    raise "kafka-batch gem not found — clone to ../kafka-batch or set KAFKA_BATCH_GEM_PATH" unless found

    found
  end
end

gem "kafka-batch", path: kafka_batch_gem_path
gem "activerecord", ">= 6.0"
gem "railties", ">= 6.0"
gem "sqlite3"
gem "oj"
gem "redis"
gem "karafka", ">= 2.0"
gem "waterdrop"
